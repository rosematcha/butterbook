{
  "name": "@butterbook/shared",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./permissions": {
      "source": "./src/permissions/index.ts",
      "types": "./dist/permissions/index.d.ts",
      "default": "./dist/permissions/index.js"
    },
    "./plans": {
      "source": "./src/plans/index.ts",
      "types": "./dist/plans/index.d.ts",
      "default": "./dist/plans/index.js"
    },
    "./schemas": {
      "source": "./src/schemas/index.ts",
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    },
    "./types": {
      "source": "./src/types/index.ts",
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./errors": {
      "source": "./src/errors/index.ts",
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./utils": {
      "source": "./src/utils/index.ts",
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "echo 'shared: lint via root'",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "3.23.8"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  }
}
