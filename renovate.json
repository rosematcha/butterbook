{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "America/New_York",
  "schedule": ["before 4am on monday"],
  "labels": ["dependencies"],
  "rangeStrategy": "pin",
  "dependencyDashboard": true,
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Auto-merge security patches once CI passes.",
      "matchUpdateTypes": ["patch"],
      "matchDepTypes": ["dependencies", "devDependencies"],
      "vulnerabilityAlerts": true,
      "automerge": true,
      "schedule": ["at any time"]
    },
    {
      "description": "Major updates get their own PR and require explicit review.",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major"],
      "automerge": false
    },
    {
      "description": "Group minor TS/tooling bumps.",
      "matchPackageNames": ["typescript", "turbo", "tsx", "vitest"],
      "groupName": "typescript toolchain"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "postUpdateOptions": ["pnpmDedupe"]
}
