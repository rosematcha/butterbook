NODE_ENV=development
PORT=3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/butterbook
DATABASE_POOL_SIZE=10
# 32 bytes, base64-encoded. Generate with: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=changeme_generate_with_openssl_rand_base64_32xx
SESSION_SECRET=changeme_minimum_32_characters_session_xx
KIOSK_NONCE_SECRET=changeme_minimum_32_characters_kiosk_xx
MANAGE_TOKEN_SECRET=changeme_minimum_32_characters_manage_xx
APP_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# Optional. If set, GET /metrics requires Authorization: Bearer <this value>.
# If unset, /metrics is unavailable (404). Do not expose publicly.
# METRICS_TOKEN=a_long_random_string_at_least_16_chars

# Optional. If set, 5xx errors are reported to Sentry. 4xx are not.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Optional. Audit log archival. If AUDIT_ARCHIVE_DIR is set, `pnpm audit:archive`
# exports rows older than AUDIT_RETENTION_DAYS as JSONL and deletes them.
# AUDIT_RETENTION_DAYS=730
# AUDIT_ARCHIVE_DIR=/data/audit-archive

# Optional until Stripe Connect is enabled. Required for Phase 3 membership checkout.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_CONNECT_CLIENT_ID=ca_...
# STRIPE_WEBHOOK_SIGNING_SECRET=whsec_...
