{
  "ci": {
    "collect": {
      "staticDistDir": "apps/web/out",
      "url": [
        "/",
        "/login"
      ]
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:performance": ["warn", { "minScore": 0.80 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
