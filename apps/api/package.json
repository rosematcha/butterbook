{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "echo 'api: lint placeholder'",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node-pg-migrate --migrations-dir src/db/migrations --migration-file-language sql --database-url-var DATABASE_URL",
    "migrate:up": "pnpm migrate up",
    "migrate:down": "pnpm migrate down",
    "bootstrap": "tsx src/scripts/bootstrap.ts",
    "cleanup:idempotency": "tsx src/scripts/cleanup-idempotency.ts"
  },
  "dependencies": {
    "@butterbook/shared": "workspace:*",
    "@fastify/cors": "10.0.1",
    "@fastify/helmet": "12.0.1",
    "@fastify/rate-limit": "10.1.1",
    "@paralleldrive/cuid2": "2.2.2",
    "argon2": "0.41.1",
    "fastify": "5.1.0",
    "kysely": "0.27.4",
    "node-pg-migrate": "7.8.0",
    "otpauth": "9.3.4",
    "pg": "8.13.1",
    "pino": "9.5.0",
    "qrcode": "1.5.4",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.17.8",
    "@types/pg": "8.11.10",
    "@types/qrcode": "1.5.5",
    "@types/supertest": "6.0.2",
    "light-my-request": "^6.6.0",
    "supertest": "7.0.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
